{
  "assets": {
    "config": []
  },
  "channels": [],
  "clients": [],
  "project": {
    "formatVersion": "5.9",
    "locked": false
  },
  "resetChecks": [],
  "rfid": {
    "items": [],
    "tags": []
  },
  "scenes": {
    "system": {
      "preShow": {
        "variables": [],
        "values": [],
        "behaviors": []
      },
      "show": {
        "notes": "Mqtt Demo\n---------\n\nWrite a description of your project here.\ne.g. The world's first astonishing quest featuring an intergalactic zombie\n\n\nTODO:\n✅ Create new project\n⬜️ Make some scenes, channels, behaviours and more\n⬜️ Test and tweak the show\n⬜️ Install and connect hardware\n⬜️ Patch channels\n⬜️ Launch!",
        "variables": [],
        "values": [],
        "behaviors": [
          {
            "do": [
              {
                "type": "console_log_message",
                "message": {
                  "template": {
                    "type": "value",
                    "source": {
                      "type": "plugin_state",
                      "pluginId": "dev.stenz.mqtt",
                      "stateName": "subscribePayload"
                    }
                  }
                },
                "icon": "stream"
              }
            ],
            "type": "when",
            "value": {
              "expression": "plugins[\"dev.stenz.mqtt\"].event.mqttMessage?.value === \"testtopic/#\""
            },
            "when": {
              "template": {
                "type": "plugin_event",
                "pluginId": "dev.stenz.mqtt",
                "event": {
                  "key": "mqttMessage",
                  "value": "test/cogsTest"
                }
              }
            },
            "name": "MQTT Client: mqttMessage"
          },
          {
            "type": "manual",
            "parameters": [
              [
                "topic",
                {
                  "type": "string",
                  "value": "",
                  "default": "",
                  "required": true
                }
              ],
              [
                "payload",
                {
                  "type": "string",
                  "value": "",
                  "default": "",
                  "required": true
                }
              ],
              [
                "QoS",
                {
                  "type": "number",
                  "min": 0,
                  "integer": true,
                  "value": 0,
                  "default": 0,
                  "required": false,
                  "max": 2
                }
              ],
              [
                "retainFlag",
                {
                  "type": "boolean",
                  "value": false,
                  "default": false,
                  "required": false
                }
              ],
              [
                "dupFlag",
                {
                  "type": "boolean",
                  "value": false,
                  "default": false,
                  "required": false
                }
              ]
            ],
            "do": [
              {
                "type": "update_values",
                "updates": [
                  {
                    "type": "plugin_state",
                    "pluginId": "dev.stenz.mqtt",
                    "stateName": "publishPayload",
                    "value": {
                      "template": {
                        "type": "value",
                        "source": {
                          "type": "behavior_parameter",
                          "behavior": {
                            "scenePosition": {
                              "type": "system",
                              "key": "show"
                            },
                            "behaviorName": "MQTT: Publish"
                          },
                          "parameterName": "payload"
                        }
                      }
                    }
                  },
                  {
                    "type": "plugin_state",
                    "pluginId": "dev.stenz.mqtt",
                    "stateName": "QoS",
                    "value": {
                      "template": {
                        "type": "value",
                        "source": {
                          "type": "behavior_parameter",
                          "behavior": {
                            "scenePosition": {
                              "type": "system",
                              "key": "show"
                            },
                            "behaviorName": "MQTT: Publish"
                          },
                          "parameterName": "QoS"
                        }
                      }
                    }
                  },
                  {
                    "type": "plugin_state",
                    "pluginId": "dev.stenz.mqtt",
                    "stateName": "retainFlag",
                    "value": {
                      "template": {
                        "type": "value",
                        "source": {
                          "type": "behavior_parameter",
                          "behavior": {
                            "scenePosition": {
                              "type": "system",
                              "key": "show"
                            },
                            "behaviorName": "MQTT: Publish"
                          },
                          "parameterName": "retainFlag"
                        }
                      }
                    }
                  },
                  {
                    "type": "plugin_state",
                    "pluginId": "dev.stenz.mqtt",
                    "stateName": "dupFlag",
                    "value": {
                      "template": {
                        "type": "value",
                        "source": {
                          "type": "behavior_parameter",
                          "behavior": {
                            "scenePosition": {
                              "type": "system",
                              "key": "show"
                            },
                            "behaviorName": "MQTT: Publish"
                          },
                          "parameterName": "dupFlag"
                        }
                      }
                    }
                  }
                ]
              },
              {
                "type": "send_plugin_event",
                "pluginId": "dev.stenz.mqtt",
                "eventName": "publish",
                "value": {
                  "template": {
                    "type": "value",
                    "source": {
                      "type": "behavior_parameter",
                      "behavior": {
                        "scenePosition": {
                          "type": "system",
                          "key": "show"
                        },
                        "behaviorName": "MQTT: Publish"
                      },
                      "parameterName": "topic"
                    }
                  }
                }
              }
            ],
            "name": "MQTT: Publish"
          },
          {
            "type": "manual",
            "parameters": [
              [
                "topic",
                {
                  "type": "string",
                  "value": "",
                  "default": "",
                  "required": true
                }
              ]
            ],
            "do": [
              {
                "type": "send_plugin_event",
                "pluginId": "dev.stenz.mqtt",
                "eventName": "subscribe",
                "value": {
                  "template": {
                    "type": "value",
