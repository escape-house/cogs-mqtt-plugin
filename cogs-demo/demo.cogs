                      "type": "behavior_parameter",
                      "behavior": {
                        "scenePosition": {
                          "type": "system",
                          "key": "show"
                        },
                        "behaviorName": "MQTT: Subscribe"
                      },
                      "parameterName": "topic"
                    }
                  }
                }
