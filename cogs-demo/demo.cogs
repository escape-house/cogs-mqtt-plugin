            ],
            "name": "MQTT: Subscribe"
          },
          {
            "type": "manual",
            "parameters": [
              [
                "topic",
                {
                  "type": "string",
                  "value": "",
                  "default": "",
                  "required": true
                }
              ]
            ],
            "do": [
              {
                "type": "send_plugin_event",
                "pluginId": "dev.stenz.mqtt",
                "eventName": "unsubscribe",
                "value": {
                  "template": {
                    "type": "value",
                    "source": {
                      "type": "behavior_parameter",
                      "behavior": {
                        "scenePosition": {
                          "type": "system",
                          "key": "show"
                        },
                        "behaviorName": "MQTT: Unsubscribe"
                      },
                      "parameterName": "topic"
                    }
                  }
                }
              }
            ],
            "name": "MQTT: Unsubscribe"
          }
        ],
        "dashboard": [
          {
            "label": "",
            "rows": [
              {
                "label": "MQTT Server Status",
                "alignment": "center",
                "widgets": [
                  {
                    "type": "value",
